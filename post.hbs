{{!< default}}
{{!-- The tag above means: insert everything in this file into the body of the default.hbs template --}}

{{#post}}

<main class="gh-main">

    <article class="gh-article {{post_class}}">

        <header class="gh-article-header gh-canvas">

            <h1 class="gh-article-title is-title">{{title}}</h1>
            {{#if custom_excerpt}}
                <p class="gh-article-excerpt is-body">{{custom_excerpt}}</p>
            {{/if}}

            {{#if @custom.show_post_metadata}}
            <div class="gh-article-meta">
                <div class="gh-article-author-image instapaper_ignore">
                    {{#foreach authors}}
                        {{#if profile_image}}
                            <a href="{{url}}">
                                <img class="author-profile-image" src="{{img_url profile_image size="xs"}}" alt="{{name}}">
                            </a>
                        {{else}}
                            <a href="{{url}}">{{> "icons/avatar"}}</a>
                        {{/if}}
                    {{/foreach}}
                </div>
                <div class="gh-article-meta-wrapper">
                    <h4 class="gh-article-author-name">{{authors}}</h4>
                    <div class="gh-article-meta-content">
                        <time class="gh-article-meta-date" datetime="{{date format="YYYY-MM-DD"}}">{{date}}</time>
                        {{#if reading_time}}
                            <span class="gh-article-meta-length"><span class="bull">—</span> {{reading_time}}</span>
                        {{/if}}
                    </div>
                </div>
            </div>
            {{/if}}

            {{> "feature-image"}}

        </header>

        <section class="gh-content gh-canvas is-body{{#if @custom.enable_drop_caps_on_posts}} drop-cap{{/if}}">
            {{content}}
        </section>

        {{#if tags}}
        <section class="gh-article-tag gh-canvas" style="margin-top: 24px; text-align: center;">
          <div>
            {{tags}}
          </div>
        </section>
        {{/if}}

        <section class="gh-canvas" style="text-align: center;">
        <div>
          {{#prev_post}}
          ← <a class="gh-article-tag" href="{{url}}">{{title}}</a>
          {{/prev_post}}
          |
          {{#next_post}}
          <a class="gh-article-tag" href="{{url}}">{{title}}</a> →
          {{/next_post}}
        </div>
        </section>        
        
    </article>

        {{!-- Discourse comments: Configure by adding custom settings or using Ghost code injection --}}
        <div class="gh-comments gh-canvas">
            <div id='discourse-comments'></div>

            <script type="text/javascript">
             // Configure these settings in Ghost theme customization
             DiscourseEmbed = {
               discourseUrl: window.discourseUrl || '', // Set via Ghost theme settings or code injection
               discourseEmbedUrl: '{{url absolute="true"}}',
             };
             // For WP-era posts whose embed_url was stored with a trailing slash,
             // window.DISCOURSE_TOPIC_ID is injected via codeinjection_head.
             // Passing topicId lets the embed JS bypass the URL lookup entirely.
             if (window.DISCOURSE_TOPIC_ID) {
               DiscourseEmbed.topicId = window.DISCOURSE_TOPIC_ID;
             }

             // Only load Discourse embed if URL is configured
             if (DiscourseEmbed.discourseUrl) {
               (function() {
                 var d = document.createElement('script'); d.type = 'text/javascript'; d.async = true;
                 d.src = DiscourseEmbed.discourseUrl + 'javascripts/embed.js';
                 (document.getElementsByTagName('head')[0] || document.getElementsByTagName('body')[0]).appendChild(d);
               })();
             }
            </script>
        </div>

</main>

{{/post}}

{{#if @custom.show_related_articles}}

  {{> related reltags=post.tags exclude=post.id}}

{{/if}}
